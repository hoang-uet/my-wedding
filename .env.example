# Supabase — lấy từ https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Admin Dashboard — PIN 4-6 chữ số để truy cập /tao-thiep
VITE_ADMIN_PIN=1234

# Site URL — BẮT BUỘC cho OG meta tags (social preview khi chia sẻ link)
# Vite thay thế %VITE_SITE_URL% trong index.html lúc build
VITE_SITE_URL=https://your-wedding-site.vercel.app
